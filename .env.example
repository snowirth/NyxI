# Fastest first run:
#   1. ./scripts/first_run_local.sh
#   2. ./scripts/first_run_local.sh --smoke
#   3. ./scripts/first_run_local.sh --run

# Set to 1 so a second pass reloads .env and lets .env win over exported shell variables.
NYX_DOTENV_OVERRIDE=

# User chat provider. Leave empty for runtime auto:
#   - Anthropic if NYX_ANTHROPIC_API_KEY is set
#   - NIM if NYX_NIM_API_KEY is set
#   - Ollama otherwise
# The bootstrap script will fill this when it can prove a provider is ready.
NYX_CHAT_PRIMARY=

# Hosted providers
NYX_ANTHROPIC_API_KEY=
NYX_ANTHROPIC_MODEL=
NYX_NIM_API_KEY=
# Optional OpenAI-compatible chat base (no trailing /v1). Leave empty for https://integrate.api.nvidia.com
NYX_NIM_BASE_URL=
NYX_NIM_MODEL=

# Ollama: fastest fully local path
# Leave NYX_OLLAMA_MODEL empty if you are using ./scripts/first_run_local.sh.
# The script will detect a model from `ollama list` and write it into .env.
# If you are configuring manually, set this to an installed model name exactly as shown by `ollama list`.
NYX_OLLAMA_HOST=http://127.0.0.1:11434
NYX_OLLAMA_MODEL=

# First-run quality of life
# Overnight idle loop: default 1.0; higher = shorter waits between ticks when user is away (max 4.0)
NYX_OVERNIGHT_SPEED=
NYX_WEB_PORT=8099
# Leave empty and the bootstrap script will generate a bearer token for the web API.
NYX_API_TOKEN=
# Directories to watch for file changes
NYX_WATCH_DIRS=.
# Auto-detected if empty
NYX_USER_NAME=
# Auto-detected from IP if empty
NYX_USER_LOCATION=
# Auto-detected if empty
NYX_DEFAULT_CITY=
# For GitHub integration
NYX_GITHUB_REPO=

# Optional channels
NYX_TELEGRAM_TOKEN=
NYX_TELEGRAM_OWNER_IDS=
NYX_DISCORD_TOKEN=

# Optional Twitter
NYX_TWITTER_USERNAME=
NYX_TWITTER_PASSWORD=
NYX_TWITTER_EMAIL=
